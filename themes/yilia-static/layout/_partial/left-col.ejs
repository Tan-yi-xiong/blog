<div class="left-col" q-class="show:isShow">
  <div class="overlay" style="background: #4d4d4d"></div>
  <div class="intrude-less">
    <header id="header" class="inner">
      <a href="<%- url_for('/') %>" class="profilepic">
        <img src="<%- theme.avatar %>" class="js-avatar">
      </a>
      <hgroup>
        <h1 class="header-author"><a href="<%- url_for('/') %>"><%- theme.author || config.author %></a></h1>
      </hgroup>
      <p class="header-subtitle"><%- theme.subtitle %></p>
      <nav class="header-menu">
        <ul>
          <li><a href="<%- url_for('/') %>">主页</a></li>
        </ul>
      </nav>
      <nav class="header-smart-menu">
        <a q-on="click: openSlider(e, 'innerArchive')" target="_self" href="javascript:void(0)">所有文章</a>
        <a q-on="click: openSlider(e, 'aboutme')" target="_self" href="javascript:void(0)">关于我</a>
      </nav>
      <nav class="header-nav">
        <div class="social">
          <a class="github" target="_blank" href="<%- theme.github %>" title="github"><i class="icon-github"></i></a>
          <a class="weibo" target="_blank" href="<%- theme.weibo %>" title="weibo"><i class="icon-weibo"></i></a>
        </div>
      </nav>
    </header>
  </div>
</div>
