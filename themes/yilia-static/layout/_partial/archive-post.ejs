<article class="archive-article archive-type-post">
  <div class="archive-article-inner">
    <header class="archive-article-header">
      <a href="<%- url_for(post.path) %>" class="archive-article-date">
        <time datetime="<%- date_xml(post.date) %>"><i class="icon-calendar icon"></i><%- date(post.date, config.date_format) %></time>
      </a>
      <h1 itemprop="name">
        <a class="archive-article-title" href="<%- url_for(post.path) %>"><%- post.title %></a>
      </h1>
    </header>
  </div>
</article>
